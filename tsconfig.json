{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@api/*":            ["src/api/*"],
      "@auth/*":           ["src/auth/*"],
      "@components/*":     ["src/components/*"],
      "@config/*":         ["src/config/*"],
      "@hooks/*":          ["src/hooks/*"],
      "@navigation/*":     ["src/navigation/*"],
      "@notifications/*":  ["src/notifications/*"],
      "@screens/*":        ["src/screens/*"],
      "@store/*":          ["src/store/*"],
      "@models/*":         ["src/types/*"],
      "@utils/*":          ["src/utils/*"]
    }
  }
}
